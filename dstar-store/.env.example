# ============================================
# DSTAR STORE — Variables de entorno
# ============================================
# Copia este archivo como .env para desarrollo local.
# NUNCA subas el .env real al repositorio.
#
# En Netlify: configura estas variables en
# Site settings → Environment variables
# ============================================

# --- SKYDROPX PRO (API v2 / OAuth2) ---
# Credenciales OAuth de Skydropx Pro (Configuración → API).
SKYDROPX_CLIENT_ID=tu_client_id_de_skydropx_pro
SKYDROPX_CLIENT_SECRET=tu_client_secret_de_skydropx_pro

# --- ORIGEN DEL ENVÍO (almacén DSTAR) ---
# La cotización Pro EXIGE estado/municipio/colonia además del CP.
CP_ORIGEN=50000
ORIGEN_ESTADO=Estado de México
ORIGEN_MUNICIPIO=Toluca
ORIGEN_COLONIA=Centro
DIRECCION_ORIGEN=Calle y Numero
TELEFONO_ORIGEN=7221234567
EMAIL_ORIGEN=tienda@dstar.mx
NOMBRE_ORIGEN=DSTAR Store
EMPRESA_ORIGEN=DSTAR
REFERENCIA_ORIGEN=Almacén DSTAR

# Claves de catálogo para la guía (ajusta si Skydropx rechaza alguna).
SKYDROPX_CONSIGNMENT_NOTE=53102400
SKYDROPX_PACKAGE_TYPE=4G

# --- CORREO (Gmail SMTP / nodemailer) ---
# GMAIL_APP_PASSWORD = "Contraseña de aplicación" de Google (requiere 2FA).
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=tu_app_password_de_16_caracteres

# --- MERCADO PAGO ---
# Access token de producción (empieza con APP_USR-)
# Para pruebas usa el access token de sandbox (empieza con TEST-)
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago

# --- SITIO ---
# URL pública de tu sitio en Netlify (sin slash final)
URL_SITIO=https://tu-sitio.netlify.app
