# ============================================
# DSTAR STORE — Variables de entorno
# ============================================
# Copia este archivo como .env para desarrollo local.
# NUNCA subas el .env real al repositorio.
#
# En Netlify: configura estas variables en
# Site settings → Environment variables
# ============================================

# --- SKYDROPX ---
# Token de API de Skydropx (tu cuenta de envíos)
SKYDROPX_API_KEY=tu_token_de_skydropx

# Código postal de origen (almacén DSTAR en Toluca)
CP_ORIGEN=50000

# Dirección completa del remitente
DIRECCION_ORIGEN=Calle y Numero, Colonia

# Teléfono de contacto del remitente
TELEFONO_ORIGEN=7221234567

# Email del remitente (aparece en la guía)
EMAIL_ORIGEN=tienda@dstar.mx

# --- MERCADO PAGO ---
# Access token de producción (empieza con APP_USR-)
# Para pruebas usa el access token de sandbox (empieza con TEST-)
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago

# --- SITIO ---
# URL pública de tu sitio en Netlify (sin slash final)
URL_SITIO=https://tu-sitio.netlify.app
